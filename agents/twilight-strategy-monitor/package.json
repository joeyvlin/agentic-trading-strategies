{
  "name": "twilight-strategy-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Poll Twilight Strategy API, enforce risk limits, execute in simulation or real mode",
  "bin": {
    "twilight-strategy-monitor": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "start:sim": "AGENT_MODE=simulation node src/index.js",
    "start:real": "AGENT_MODE=real node src/index.js",
    "once": "node src/index.js --once",
    "check:upstream": "node scripts/check-upstream.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ccxt": "^4.4.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0"
  }
}
