# Copy to repo root as `.env` (never commit `.env`).

# --- Agent ---
# AGENT_MODE=simulation
# AGENT_MODE=real
# AGENT_CONFIG_PATH=/absolute/path/to/agent.monitor.yaml
# LOG_LEVEL=info

# --- Web dashboard (dashboard/server.mjs) ---
# DASHBOARD_PORT=3847
# DASHBOARD_HOST=127.0.0.1   # omit to bind all interfaces (helps localhost / IPv6 quirks)
# DASHBOARD_TOKEN=
#
# Real mode safety gate — required for live orders (dashboard “Real” / execution.mode real).
# Prefer the “Allow real trading” toggle in Twilight wallet (step 1); it writes this line:
# CONFIRM_REAL_TRADING=YES

# --- Twilight Strategy API ---
# STRATEGY_API_BASE_URL=http://134.199.214.129:3000
# STRATEGY_API_KEY=your_key_here

# --- Twilight testnet faucet (for dashboard “Request NYKS”) ---
# FAUCET_BASE_URL=https://faucet-rpc.twilight.rest

# --- Binance (USDM futures via ccxt) ---
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BINANCE_USE_TESTNET=1

# --- Bybit (inverse perp leg via ccxt) ---
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
# BYBIT_USE_TESTNET=1

# --- Twilight relayer-cli (required for dashboard wallet / faucet / orders) ---
# If you see "spawn relayer-cli ENOENT", set the full path to the binary:
# TWILIGHT_RELAYER_CLI=/path/to/nyks-wallet/target/release/relayer-cli
#
# Auto-install during `npm install` in dashboard/ (writes tools/relayer-cli; see docs/deploy-relayer.md):
# RELAYER_CLI_URL=https://example.com/relayer-cli-linux-x86_64
# RELAYER_CLI_BUILD=1
# SKIP_RELAYER_CLI_INSTALL=1
# ALLOW_TWILIGHT_CLI_EXECUTION=1
# TWILIGHT_ACCOUNT_INDEX=0

# --- Wallet env for relayer-cli (see nyks-wallet) ---
# NYKS_WALLET_ID=
# NYKS_WALLET_PASSPHRASE=
#
# Dashboard relayer: ZkOS fund / transfer (localhost only):
# RELAYER_ALLOW_DASHBOARD_ZK=YES
# Dashboard relayer: order open/close/cancel (localhost only):
# RELAYER_ALLOW_DASHBOARD_ORDERS=YES
